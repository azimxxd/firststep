# OpenAI Responses API (server-side only). Used when HF_TOKEN is empty.
AI_API_KEY=
AI_API_MODE=responses
AI_MODEL=gpt-5-mini-2025-08-07
AI_MAX_OUTPUT_TOKENS=240

# Groq Free is an OpenAI-compatible production alternative.
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3.6-27b

# Hugging Face Inference Providers (server-side only; takes precedence over AI_API_KEY).
HF_TOKEN=
HF_MODEL=Qwen/Qwen3-4B-Instruct-2507
HF_FALLBACK_MODEL=Qwen/Qwen3-8B
HF_MAX_TOKENS=240

# Required automatically when VERCEL_ENV=production. Preview/local may omit these.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Vercel Marketplace Upstash may provide these aliases instead:
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Generate at least 32 random characters. Never expose it with NEXT_PUBLIC_.
RATE_LIMIT_HASH_SECRET=
RATE_LIMIT_MAX_REQUESTS=12
RATE_LIMIT_WINDOW_SECONDS=60
# Set true to test the production fail-closed gate outside Vercel.
REQUIRE_PRODUCTION_CONTROLS=false

# To use OpenAI Chat Completions instead of Responses, set a compatible model and use:
# AI_API_MODE=chat-completions
